# Decimal API secrets only.
# Non-secret runtime settings live in config/api.config.json.
DATABASE_URL="postgresql://usdc_ops:usdc_ops@127.0.0.1:54329/usdc_ops?schema=public"
LOG_LEVEL=info
OAUTH_STATE_SECRET=replace-me-with-a-long-random-secret
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override. Defaults to {publicApiUrl}/auth/google/callback.
GOOGLE_OAUTH_REDIRECT_URI=
# Optional managed-wallet provider. Required to create Privy Solana wallets from the API.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_API_BASE_URL=https://api.privy.io
# Automatically provision a Privy personal wallet on org join and a default
# Decimal agent wallet on org creation. Defaults to true when Privy is
# configured outside NODE_ENV=test.
AUTO_PROVISION_WALLETS=true
# Resend email provider. If unset, /auth/register falls back to returning the verification code in the response (dev only).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Decimal
# OpenAI — powers the doc-to-proposal pipeline (invoice PDF/image → payment orders/runs).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: keep a private backend RPC here.
# SOLANA_NETWORK controls which Solana cluster the API targets.
# Affects USDC mint, Squads/treasury operations, and the network advertised to the frontend via /capabilities.
SOLANA_NETWORK=devnet
# SOLANA_NETWORK=mainnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
# Devnet-only fee funding for newly created Privy personal/agent wallets.
# Generate a local keypair, fund it with devnet SOL, then enable this.
DEVNET_AUTO_FUND_WALLETS=false
DEVNET_FUNDER_KEYPAIR_PATH=.secrets/devnet-funder.json
DEVNET_AUTO_FUND_LAMPORTS=5000000
