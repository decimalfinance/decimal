# Yellowstone worker secrets only.
# Non-secret runtime settings live in config/worker.config.json.
YELLOWSTONE_TOKEN=
# Optional: if your Yellowstone provider treats the endpoint itself as sensitive.
YELLOWSTONE_ENDPOINT=https://solana-rpc.example.com:10443
# Optional: only if ClickHouse is protected with auth.
CLICKHOUSE_PASSWORD=
CONTROL_PLANE_SERVICE_TOKEN=replace-me-for-prod
